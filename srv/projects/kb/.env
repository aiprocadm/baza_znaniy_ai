# Application environment configuration
APP_HOST=kb.local
APP_PORT=8000
APP_RELOAD=false
APP_SECRET=ffffffffffffffffffffffffffffffff

# Data directories
DATA_DIR=/data/storage

# Model settings
GEN_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=intfloat/multilingual-e5-small

# Storage
FILES_ROOT=/srv/projects/kb/data/files

# Vector search settings
VECTOR_SIZE=384
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_API_KEY=

# Logging
LOG_LEVEL=INFO

# Retrieval parameters
RAG_TOKENIZER_NAME=cl100k_base
RAG_CHUNK=900
RAG_OVERLAP=140
RETRIEVE_TOPK=24
RERANK_TOPK=8

# Chat memory
CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_TTL_DAYS=90
CHAT_SUMMARY_TRIGGER=10
CHAT_MEMORY_MAXTOK=2000
CHAT_HISTORY_LIMIT=12
CHAT_MIN_CITATIONS=3
CHAT_MAX_CITATIONS=5

# Basic auth
BASIC_USER=admin

# Rate limiting
RATE_LIMIT=30r/m
RATE_BURST=20

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
