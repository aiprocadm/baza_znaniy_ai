# Базовые настройки приложения
APP_SECRET=change-me
FILES_ROOT=/opt/knowlab/data/files

# Настройки моделей
GEN_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=intfloat/multilingual-e5-small
OLLAMA_HOST=http://ollama:11434

# Параметры поиска
RAG_CHUNK=900
RAG_OVERLAP=140
RETRIEVE_TOPK=10

# PostgreSQL
POSTGRES_DB=knowlab
POSTGRES_USER=knowlab
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://knowlab:change-me@postgres:5432/knowlab

# Дополнительные параметры
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_API_KEY=
