# Базовые настройки приложения
DATA_DIR=/app/var/data
# При необходимости можно переопределить каталог с файлами, иначе используется DATA_DIR/files
# FILES_ROOT=/app/var/data/files

# Параметры БД для истории чатов
# CHAT_DB_BACKEND=postgres
# CHAT_DB_DSN=postgresql://user:password@localhost:5432/chat
# CHAT_DB_SCHEMA=public

# Настройки моделей
GEN_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=intfloat/multilingual-e5-small
OLLAMA_HOST=http://ollama:11434

# Параметры поиска
RAG_CHUNK=900
RAG_OVERLAP=140
RETRIEVE_TOPK=10

# Дополнительные параметры
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_API_KEY=
