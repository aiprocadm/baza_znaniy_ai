# Пример конфигурации окружения для kb_ai
# Скопируйте файл и обновите значения под вашу среду.

APP_SECRET=change-me
FILES_ROOT=/opt/knowlab/data/files

GEN_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=intfloat/multilingual-e5-small
OLLAMA_HOST=http://ollama:11434

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_API_KEY=

PGHOST=postgres
PGPORT=5432
PGDATABASE=knowlab
PGUSER=knowlab
PGPASSWORD=change-me

CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_TTL_DAYS=90
CHAT_SUMMARY_TRIGGER=10
CHAT_MEMORY_MAXTOK=2000

RAG_CHUNK=900
RAG_OVERLAP=140
        codex/split-existing-service-into-containers
QDRANT_COLLECTION=kb_chunks
QDRANT_HOST=qdrant
QDRANT_PORT=6333
OLLAMA_BASE_URL=http://ollama:11434
POSTGRES_DB=kb
POSTGRES_USER=kb
POSTGRES_PASSWORD=kb-secret
DATABASE_URL=postgresql://kb:kb-secret@db:5432/kb

        codex/split-monolithic-image-into-separate-services
RETRIEVE_TOPK=24

QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=kb_chunks
        main
        main
