# Пример конфигурации окружения для kb_ai
# Скопируйте файл и обновите значения под вашу среду.

APP_SECRET=change-me
FILES_ROOT=/opt/knowlab/data/files

GEN_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=intfloat/multilingual-e5-small
OLLAMA_HOST=http://ollama:11434

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_API_KEY=

PGHOST=postgres
PGPORT=5432
PGDATABASE=knowlab
PGUSER=knowlab
PGPASSWORD=change-me

CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_TTL_DAYS=90
CHAT_SUMMARY_TRIGGER=10
CHAT_MEMORY_MAXTOK=2000

RAG_CHUNK=900
RAG_OVERLAP=140
RETRIEVE_TOPK=24
