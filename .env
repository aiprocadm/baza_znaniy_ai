# Уже есть, не затирать:
APP_HOST=kb.local

# Сервисные параметры
APP_PORT=8080
APP_SECRET=ffffffffffffffffffffffffffffffff  # замените позже в nano на случайный 32-hex

# Модели
GEN_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=intfloat/multilingual-e5-small     # строго e5-small

# Qdrant-плейсхолдеры (используем локальный FAISS)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=kb_chunks

# Параметры RAG
RAG_CHUNK=900
RAG_OVERLAP=140
RETRIEVE_TOPK=24
RERANK_TOPK=8

# Память диалогов
CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_TTL_DAYS=90
CHAT_SUMMARY_TRIGGER=10
CHAT_MEMORY_MAXTOK=2000

# Nginx BasicAuth
BASIC_USER=admin

# Rate limit
RATE_LIMIT=30r/m
RATE_BURST=20
