# Базовые параметры приложения
APP_HOST=kb.local
APP_PORT=8080
APP_SECRET=ffffffffffffffffffffffffffffffff

# Пути к данным
FILES_ROOT=/opt/knowlab/data/files

# LLM и эмбеддинги
GEN_MODEL=qwen2.5:3b-instruct
EMBED_MODEL=intfloat/multilingual-e5-small

# Хранилища
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_API_KEY=
PGHOST=postgres
PGPORT=5432
PGDATABASE=knowlab
PGUSER=knowlab
PGPASSWORD=change-me

# Параметры RAG
RAG_CHUNK=900
RAG_OVERLAP=140
RETRIEVE_TOPK=24
RERANK_TOPK=8

# Память диалогов
CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_TTL_DAYS=90
CHAT_SUMMARY_TRIGGER=10
CHAT_MEMORY_MAXTOK=2000

# Ollama и API
OLLAMA_HOST=http://ollama:11434

# Nginx BasicAuth
BASIC_USER=admin

# Rate limit
RATE_LIMIT=30r/m
RATE_BURST=20
