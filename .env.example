# Application settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Core data paths
DATA_DIR=./var/data
DB_URL=sqlite+aiosqlite:///./var/data/kb.sqlite
# Local SQLite store backing the MVP /api/kb/* endpoints
KB_MVP_DB_PATH=./var/data/kb_mvp.sqlite

# --- MVP /api/kb/* — LLM providers ----------------------------------------
# Explicit provider name (deepseek|groq|openrouter|openai|ollama|custom).
# Leave empty for auto-detect by key.
KB_LLM_PROVIDER=
# Tuning shared by all OpenAI-compatible providers
KB_LLM_TIMEOUT=60
KB_LLM_MAX_TOKENS=1024
KB_LLM_TEMPERATURE=0.2

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Groq (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_REFERER=
OPENROUTER_TITLE=

# OpenAI (https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (локально). Используется явно через KB_LLM_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- MVP /api/kb/* — Embeddings -------------------------------------------
# hash|ollama|api. Empty = auto (ollama если задан OLLAMA_EMBED_MODEL, иначе hash).
KB_EMBEDDINGS_BACKEND=
OLLAMA_EMBED_MODEL=
EMBEDDINGS_API_BASE_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_API_MODEL=text-embedding-3-small

# --- MVP /api/kb/* — Authentication (opt-in) ------------------------------
# Если задан — все эндпоинты /api/kb/* кроме /health и /providers требуют
# заголовок X-API-Key с этим значением. Пусто — auth выключен (dev-режим).
# Для prod-деплоя на публичный IP — ОБЯЗАТЕЛЬНО задать.
KB_API_KEY=

# --- MVP /api/kb/* — DoS protection ---------------------------------------
# Максимальное количество чанков, которое kb_store.search извлекает в Python
# за один запрос для cosine-скоринга. Защищает от OOM при больших корпусах.
KB_SEARCH_HARD_LIMIT=10000

# --- MVP /api/kb/* — Cross-encoder reranker -------------------------------
# Включает двухэтапный retrieval: bi-encoder shortlist → cross-encoder rerank.
# Дефолт false — модель не загружается, никаких сетевых вызовов.
KB_RERANK_ENABLED=false
# Lightweight default (~80 MB, English).
# Для русского/многоязычного контента: KB_RERANK_MODEL=BAAI/bge-reranker-v2-m3 (~600 MB).
KB_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Сколько кандидатов брать из bi-encoder (k1).
KB_RERANK_CANDIDATES=20
# Финальный лимит после rerank (k2).
KB_RERANK_TOPN=5
# Batch size для CrossEncoder.predict.
KB_RERANK_BATCH=32

# Upload configuration
MAX_UPLOAD_MB=40
UPLOAD_ALLOWED_EXTS=pdf,docx,pptx,xlsx,txt,md

# Vector store configuration
VECTOR_BACKEND=qdrant
QDRANT_URL=
QDRANT_PATH=./var/data/qdrant
QDRANT_COLLECTION=kb_chunks
QDRANT_API_KEY=
VECTOR_EMBED_MODEL=intfloat/multilingual-e5-small
VECTOR_EMBED_DIMENSION=384
EMBED_BATCH_SIZE=64
RETRIEVE_TOPK=10
RERANK_ENABLED=true
RERANK_TOPK=50

# Language model configuration
# LoRA training defaults
USE_LORA=1
LORA_DEFAULT_ADAPTER=none
LORA_REGISTRY_DIR=./data/lora/registry
LORA_TRAIN_BASE_MODEL=meta-llama/Llama-3-8b-Instruct
LORA_TRAIN_MAX_SEQ_LEN=4096
LORA_TRAIN_OUTPUT_DIR=./data/lora/runs
LORA_FP16=1
LORA_BF16=0
LORA_USE_QLORA=1
LLM_PROVIDER=llama-cpp
LLM_MODEL_NAME=kb-llama
LLM_MODEL_PATH=./models/model.gguf
LLM_CTX=4096
LLM_THREADS=4
LLM_GPU_LAYERS=0
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95
LLM_TOP_K=40
LLM_MAX_TOKENS=1024
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_API_MODEL=gpt-4o-mini
LLM_API_TIMEOUT_SEC=60
LORA_ADAPTER_PATH=
LORA_SCALING=1.0
HUGGINGFACE_HUB_TOKEN=

# Chat history storage
CHAT_DB_BACKEND=sqlite
CHAT_DB_PATH=
CHAT_DB_DSN=
CHAT_DB_SCHEMA=
CHAT_HISTORY_LIMIT=12
CHAT_SUMMARY_TRIGGER=10
CHAT_MIN_CITATIONS=3
CHAT_MAX_CITATIONS=5

# Memory subsystem
CHAT_MEMORY_ENABLED=false
MEMORY_DB_PATH=
CHAT_MEMORY_TTL_DAYS=90
CHAT_MEMORY_MAXTOK=2000

# Ingestion defaults
RAG_TOKENIZER_NAME=cl100k_base
RAG_CHUNK=900
RAG_OVERLAP=140
INGEST_USE_LOCAL_QUEUE=true
INGEST_AUTOSTART_WORKER=true
OCR_TESSERACT_CMD=
OCR_DPI=300
OCR_PAGE_LIMIT=
OCR_TIMEOUT_SECONDS=
DOCUMENT_PARSER_BACKEND=auto
DOCLING_ENABLED=true
DOCLING_TIMEOUT=180
DOCLING_OCR_ENABLED=false
DOCLING_MAX_PAGES=200

# Security
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# LangChain integration (disabled by default for backward compatibility)
LANGCHAIN_ENABLED=false
LANGCHAIN_MODE=legacy
LANGCHAIN_USE_HISTORY_AWARE=false
LANGCHAIN_RETURN_SOURCE_DOCS=false
LANGCHAIN_TRACING=false
LANGCHAIN_PROJECT=kb-ai

# Infrastructure for optional integrations
REDIS_URL=
RATE_LIMIT_BACKEND=memory
POSTGRES_DSN=

# API key hashing and billing (disabled by default)
API_KEY_HASH_SALT=kb-ai-salt
BILLING_ENABLED=false
BILLING_PROVIDER=none


QDRANT_IMAGE_TAG=v1.15.4

# ──────────────────────────────────────────────────────────────────────
# Compliance Mode (Phase 2 заготовка — НЕ имплементирована в v1.0)
# ──────────────────────────────────────────────────────────────────────
# Когда задан, /api/kb/health эхо-возвращает значение в поле
# "compliance_mode". Реальная фильтрация LLM-провайдеров (запретить
# западные облака в ru_strict, и т.п.) — отложена до явного pilot-
# запроса. См. ROADMAP.md.
#
# Допустимые значения (для будущего использования):
#   ru_strict       — local llama.cpp + GigaChat + YandexGPT
#   kz_strict       — local + Ollama (RU облака запрещены)
#   by_strict       — аналогично KZ
#   cis_universal   — только local llama.cpp + Ollama
#
# KB_COMPLIANCE_MODE=
