# Application settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Core data paths
DATA_DIR=./var/data
DB_URL=sqlite+aiosqlite:///./var/data/kb.sqlite

# Upload configuration
MAX_UPLOAD_MB=25
UPLOAD_ALLOWED_EXTS=pdf,docx,txt

# Vector store configuration
VECTOR_BACKEND=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=kb_chunks
QDRANT_API_KEY=
VECTOR_EMBED_MODEL=intfloat/multilingual-e5-small
VECTOR_EMBED_DIMENSION=384
EMBED_BATCH_SIZE=32

# Language model configuration
LLM_PROVIDER=ollama
        codex/update-default-model-and-settings
LLM_MODEL_NAME=llama3.1:8b
OLLAMA_BASE_URL=http://ollama:11434
MAX_CONTEXT_TOKENS=6000
MAX_GENERATION_TOKENS=

        codex/expand-env.example-and-update-configuration
LLM_MODEL_NAME=qwen2.5:3b-instruct
OLLAMA_MODEL=qwen2.5:3b-instruct
OLLAMA_BASE_URL=http://ollama:11434
MAX_CONTEXT_TOKENS=6000
MAX_GENERATION_TOKENS=512

LLM_MODEL_NAME=llama3.1:8b
OLLAMA_BASE_URL=http://ollama:11434
MAX_CONTEXT_TOKENS=6000
MAX_GENERATION_TOKENS=1024
        main
        main

# Chat history storage
CHAT_DB_BACKEND=sqlite
CHAT_DB_PATH=
CHAT_DB_DSN=
CHAT_DB_SCHEMA=
CHAT_HISTORY_LIMIT=12
CHAT_SUMMARY_TRIGGER=10
CHAT_MIN_CITATIONS=3
CHAT_MAX_CITATIONS=5
RETRIEVE_TOPK=10
RERANK_ENABLED=false
RERANK_TOPK=10

# Memory subsystem
CHAT_MEMORY_ENABLED=false
MEMORY_DB_PATH=
CHAT_MEMORY_TTL_DAYS=90
CHAT_MEMORY_MAXTOK=2000

# Ingestion defaults
RAG_TOKENIZER_NAME=cl100k_base
RAG_CHUNK=900
RAG_OVERLAP=140
MAX_UPLOAD_MB=40

# Security
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
